# GitHub Portfolio Generator - Configuration
# Rename this file to .env and fill in your details

# Your GitHub Personal Access Token (Recommended to avoid rate limits)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_token_here

# Flask Secret Key (for sessions)
FLASK_SECRET_KEY=generate_a_random_string_here

# AI Configuration (Get your key from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
